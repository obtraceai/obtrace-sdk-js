{
  "name": "@obtrace/sdk-js",
  "version": "1.0.2",
  "description": "Obtrace backend JavaScript SDK for Node.js and Bun",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./node": {
      "types": "./dist/types/node_entry.d.ts",
      "import": "./dist/node_entry.js",
      "require": "./dist/cjs/node_entry.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "node": [
        "./dist/types/node_entry.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/build-cjs.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
  }
}
